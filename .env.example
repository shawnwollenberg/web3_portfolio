ALCHEMY_API_KEY=
MY_WALLET_ADDRESS=0xYourReceivingWalletHere
PORT=3000

# Keep true while developing locally. Set false in AWS/prod.
X402_DEV_BYPASS=true
X402_PRICE_USD=0.02
X402_NETWORK=eip155:8453
X402_FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402

# Required when using the CDP production facilitator.
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

ROOT_DOMAIN=wallyweb.com
CUSTOM_DOMAIN=walletlens.wallyweb.com
PUBLIC_BASE_URL=https://walletlens.wallyweb.com

# Free live preview demo wallet. Prefer a simple Base wallet with a few tokens.
PREVIEW_WALLET_ADDRESS=0x52E29e0d2Aa49bfBfC548C0A9F2196F4aa51f3ea
PREVIEW_WALLET_CHAINS=base
PREVIEW_CACHE_TTL_SECONDS=600

# Local paid-call test wallet. Never commit a real private key.
X402_TEST_PRIVATE_KEY=
X402_TEST_ADDRESS=0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045
X402_TEST_CHAINS=base,ethereum
X402_TEST_URL=https://walletlens.wallyweb.com/portfolio
